# Environment variables for Quarto site build
# Copy this file to .env and fill in your values

# Quarto configuration
QUARTO_DENO=true
QUARTO_DENO_V8_OPTIONS=--max-heap-size=3000

# R environment
R_LIBS_USER=/opt/R/library

# Build settings
NODE_ENV=production
NETLIFY=true

# Site metadata
SITE_URL=https://your-site.netlify.app
SITE_TITLE="Md. Jubayer Hossain"
SITE_DESCRIPTION="Personal Website for Md. Jubayer Hossain (Learner, Educator and Data Analyst)"

# Analytics (if needed)
# GOOGLE_ANALYTICS_ID=
# PLAUSIBLE_DOMAIN=

# Contact form (if using Netlify forms)
# NETLIFY_FORM_ENDPOINT=

# API keys (if needed for any integrations)
# GITHUB_TOKEN=
# ORCID_CLIENT_ID=
# ORCID_CLIENT_SECRET=