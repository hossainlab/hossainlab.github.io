        "---\n",
        "title: \"Teaching Portfolio\"\n",
        "subtitle: \"Jubayer Hossain · CHIRAL Bangladesh\"\n",
        "format:\n",
        "  html:\n",
        "    toc: false\n",
        "    page-layout: full\n",
        "css: portfolio.css\n",
        "---"
      ],
